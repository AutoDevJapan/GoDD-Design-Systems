{
  "name": "godd-design-systems",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "GoDD Design-Systems: 材化済み DESIGN.md コーパスと分類語彙 (公開 MIT)。",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build:og": "node scripts/build-og.mjs",
    "build": "node scripts/build-og.mjs && next build",
    "start": "next start",
    "validate:index": "node scripts/validate-index.mjs",
    "validate:design-md": "node scripts/validate-design-md.mjs",
    "validate:jsic": "node scripts/validate-jsic.mjs",
    "validate:taxonomy": "node scripts/validate-taxonomy.mjs",
    "legal:check": "node scripts/legal-check.mjs",
    "a11y:check": "node scripts/a11y-check.mjs",
    "build:jsic": "node scripts/build-jsic.mjs",
    "validate": "pnpm run validate:index && pnpm run validate:design-md && pnpm run validate:jsic && pnpm run validate:taxonomy && pnpm run legal:check && pnpm run a11y:check"
  },
  "dependencies": {
    "marked": "^18.0.6",
    "next": "^15.5.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.9.3"
  }
}
